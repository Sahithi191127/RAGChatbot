# Local dev — Next.js proxies /api/* to FastAPI
API_URL=http://127.0.0.1:8000

# Vercel production — set in dashboard (server-side, no NEXT_PUBLIC required):
# API_URL=https://your-app.up.railway.app

# Optional: call Railway directly from the browser instead of proxy
# NEXT_PUBLIC_API_URL=https://your-app.up.railway.app
