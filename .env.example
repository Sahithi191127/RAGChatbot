# LLM provider (Phase 6+) — Groq (OpenAI-compatible API)
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
# Set true to skip Groq and use rule-based stub (tests/CI)
USE_LLM_STUB=false

# Embeddings (Phase 2+)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Set to openai to use OpenAI embeddings instead of local sentence-transformers
EMBEDDING_PROVIDER=local

# Vector store (Phase 2+)
CHROMA_PATH=./data/index/chroma

# Ingestion (Phase 2+)
USE_CACHE=false

# Scheduler (Phase 3+) — times are UTC unless using Windows Task Scheduler at local time
# Default daily hour (UTC) when INGESTION_SCHEDULE_CRON is empty — 02:00 UTC = 07:30 IST
SCHEDULE_HOUR_UTC=2
# Recommended for 10:00 AM IST daily (10:00 IST = 04:30 UTC)
# Format: minute hour day month day-of-week
INGESTION_SCHEDULE_CRON=30 4 * * *
SCHEDULER_RETRY_ON_FAILURE=true
# Optional append-only JSON job log
SCHEDULER_LOG_PATH=./data/logs/scheduler.log

# API server (Phase 7)
API_HOST=0.0.0.0
API_PORT=8000
# Railway sets PORT automatically (app reads PORT or API_PORT)
RATE_LIMIT_PER_MINUTE=30
MAX_MESSAGE_LENGTH=4000
